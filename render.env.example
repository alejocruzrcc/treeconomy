# Copia estas keys en Render → Environment.
# Sustituye los valores; NO subas este archivo con secretos reales a git.
#
# BD: cluster Atlas de producción existente (NO el M0 staging).

DJANGO_SETTINGS_MODULE=treeproject.settings.pro
PYTHON_VERSION=3.10.14
SECRET_KEY=genera-una-clave-larga-aleatoria

# Atlas producción (cluster0.xhm1v) — mismos valores que treeproject/settings/.env
DB_HOST_PRO=mongodb+srv://treeadmin:<PASSWORD>@cluster0.xhm1v.mongodb.net/treeconomy_pro?retryWrites=true&w=majority
DB_USER_PRO=treeadmin
DB_PASSWORD_PRO=<PASSWORD>
DB_NAME_PRO=treeconomy_pro

# Actualiza con tu URL de Render (ej. treeconomy.onrender.com)
ALLOWED_HOSTS=REEMPLAZAR.onrender.com
CSRF_TRUSTED_ORIGINS=https://REEMPLAZAR.onrender.com
DOMINIO=REEMPLAZAR.onrender.com
DOMINIO_URL=https://REEMPLAZAR.onrender.com

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=
NOTIFY_EMAIL=

SOCIAL_AUTH_FACEBOOK_KEY=
SOCIAL_AUTH_FACEBOOK_SECRET=
SOCIAL_AUTH_GOOGLE_OAUTH2_KEY=
SOCIAL_AUTH_GOOGLE_OAUTH2_SECRET=

STRIPE_PUBLIC_KEY_PRO=
STRIPE_PRIVATE_KEY_PRO=
STRIPE_FREE_PRICE=
CONVERTAPI_SECRET_KEY=
MAPBOX_TOKEN=
