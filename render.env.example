# Copia estas keys en Render → Environment.
# Sustituye los valores; NO subas este archivo con secretos reales a git.

DJANGO_SETTINGS_MODULE=treeproject.settings.pro
PYTHON_VERSION=3.9.18
SECRET_KEY=genera-una-clave-larga-aleatoria

# Atlas M0 (staging) — reemplaza <PASSWORD>
DB_HOST_PRO=mongodb+srv://alejocruzzz_db_user:<PASSWORD>@treeconomy-staging.csgbd6w.mongodb.net/?appName=treeconomy-staging&retryWrites=true&w=majority
DB_USER_PRO=alejocruzzz_db_user
DB_PASSWORD_PRO=<PASSWORD>
DB_NAME_PRO=treeconomy_staging

# Actualiza cuando Render te dé la URL (ej. treeconomy.onrender.com)
ALLOWED_HOSTS=REEMPLAZAR.onrender.com
CSRF_TRUSTED_ORIGINS=https://REEMPLAZAR.onrender.com
DOMINIO=REEMPLAZAR.onrender.com
DOMINIO_URL=https://REEMPLAZAR.onrender.com

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
